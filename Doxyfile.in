PROJECT_NAME           = "Monte Carlo Instantons"
OUTPUT_DIRECTORY       = @CMAKE_SOURCE_DIR@/docs/api

INPUT                  = @CMAKE_SOURCE_DIR@/src \
                         @CMAKE_SOURCE_DIR@/docs/mainpage.dox

FILE_PATTERNS          = *.hpp *.cpp *.dox
RECURSIVE              = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES